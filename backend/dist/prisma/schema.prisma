// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// University & Course
// ─────────────────────────────────────────────

model University {
  id            String   @id @default(cuid())
  name          String
  shortName     String?
  logoUrl       String?
  address       String?
  city          String?
  country       String   @default("Germany")
  website       String?
  linkedinUrl   String?
  instagramUrl  String?
  description   String?
  ranking       Int?
  latitude      Float?
  longitude     Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  courses Course[]

  @@map("universities")
}

model Course {
  id             String   @id @default(cuid())
  universityId   String
  name           String
  description    String?
  degree         String?  // MSc, MA, MBA, etc.
  language       String?  // English, German
  duration       String?  // 2 years, 4 semesters
  fees           Float?
  feesPerSemester Float?
  currency       String   @default("EUR")
  deadline       DateTime?
  deadlineInternational DateTime?
  deadlineLabel  String?  // e.g., "International Students", "EU Students"
  startDate      DateTime?
  applicationUrl String?
  sourceUrl      String?
  ects           Int?
  applicationVia ApplicationVia @default(DIRECT)
  uniAssistInfo  String?
  requirements   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  university  University   @relation(fields: [universityId], references: [id], onDelete: Cascade)
  application Application?

  @@index([universityId])
  @@index([deadline])
  @@unique([universityId, name])
  @@map("courses")
}

enum ApplicationVia {
  DIRECT
  UNI_ASSIST
  BOTH
}

// ─────────────────────────────────────────────
// Application
// ─────────────────────────────────────────────

model Application {
  id          String            @id @default(cuid())
  intake      String?           // e.g., "WS 2026", "SS 2027" — allows same course at different intakes
  status      ApplicationStatus @default(DRAFT)
  priority    Priority          @default(MEDIUM)
  notes       String?
  appliedAt   DateTime?
  decisionAt  DateTime?
  submissionFee Float?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  courseId    String  @unique
  course     Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  documents  Document[]
  timeline   TimelineEntry[]
  checklist  ChecklistItem[]

  @@unique([courseId, intake])  // Same course + different intake = separate entries (NOT duplicate)
  @@map("applications")
}

enum ApplicationStatus {
  DRAFT
  SOP_WRITING
  DOCUMENTS_PREPARING
  DOCUMENTS_READY
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WAITLISTED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

// ─────────────────────────────────────────────
// Documents
// ─────────────────────────────────────────────

model Document {
  id            String      @id @default(cuid())
  applicationId String
  type          DocumentType
  name          String
  originalName  String
  filePath      String
  fileSize      Int
  mimeType      String
  version       Int         @default(1)
  notes         String?
  uploadedAt    DateTime    @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([type])
  @@map("documents")
}

enum DocumentType {
  SOP
  CV
  TRANSCRIPT
  BACHELOR_CERTIFICATE
  LANGUAGE_CERT_IELTS
  LANGUAGE_CERT_TOEFL
  LANGUAGE_CERT_TESTDAF
  LANGUAGE_CERT_GOETHE
  RECOMMENDATION_LETTER
  PASSPORT
  MOTIVATION_LETTER
  PORTFOLIO
  RESEARCH_PROPOSAL
  OTHER
}

// ─────────────────────────────────────────────
// Timeline
// ─────────────────────────────────────────────

model TimelineEntry {
  id            String         @id @default(cuid())
  applicationId String
  action        String
  description   String?
  type          TimelineType   @default(NOTE)
  createdAt     DateTime       @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([createdAt])
  @@map("timeline_entries")
}

enum TimelineType {
  STATUS_CHANGE
  DOCUMENT_UPLOAD
  NOTE
  DEADLINE
  EMAIL
  PAYMENT
}

// ─────────────────────────────────────────────
// Checklist
// ─────────────────────────────────────────────

model ChecklistItem {
  id            String   @id @default(cuid())
  applicationId String
  label         String
  completed     Boolean  @default(false)
  order         Int      @default(0)
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("checklist_items")
}

// ─────────────────────────────────────────────
// User Profile
// ─────────────────────────────────────────────

model Profile {
  id              String    @id @default(cuid())
  firstName       String    @default("")
  lastName        String    @default("")
  email           String    @default("")
  phone           String?
  nationality     String?
  dateOfBirth     DateTime?
  currentAddress  String?
  homeAddress     String?

  // Academic
  bachelorDegree      String?
  bachelorUniversity  String?
  bachelorGrade       Float?
  bachelorYear        Int?
  masterDegree        String?
  masterUniversity    String?
  masterGrade         Float?
  masterYear          Int?

  // Language
  ieltsScore      Float?
  ieltsDate       DateTime?
  toeflScore      Int?
  toeflDate       DateTime?
  testDafScore    Int?
  testDafDate     DateTime?
  goetheLevel     String?
  germanLevel     String?

  // GRE / GMAT
  greVerbal       Int?
  greQuant        Int?
  greAnalytical   Float?
  gmatScore       Int?

  // Work Experience
  workExperience  String?
  skills          String[]
  researchInterests String?
  publications    String?
  targetDegree    String?
  targetField     String?
  targetSemester  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

// ─────────────────────────────────────────────
// User (for auth & user count)
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  firebaseUid   String   @unique
  email         String
  displayName   String?
  photoUrl      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────────
// Calendar Events
// ─────────────────────────────────────────────

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  date        DateTime
  type        EventType @default(REMINDER)
  color       String?
  courseId    String?
  completed   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@map("calendar_events")
}

enum EventType {
  DEADLINE
  INTERVIEW
  PAYMENT
  REMINDER
  MILESTONE
}
