# ─── Database ────────────────────────────────────────────────
POSTGRES_DB=unitracker
POSTGRES_USER=unitracker
POSTGRES_PASSWORD=change_me_in_production_use_strong_password

# ─── Backend ─────────────────────────────────────────────────
DATABASE_URL=postgresql://unitracker:change_me_in_production_use_strong_password@postgres:5432/unitracker
PORT=4000
FRONTEND_URL=https://localhost
UPLOAD_DIR=/app/uploads

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://backend:4000

# ─── SSL (production) ────────────────────────────────────────
# Place your SSL certificate at nginx/ssl/cert.pem
# Place your SSL private key at nginx/ssl/key.pem
# Or run: ./nginx/gen-ssl.sh  (for self-signed dev cert)

# ─── Firebase (optional — for Google Sign-in) ───
# Create a project at https://console.firebase.google.com
# Enable Google Sign-in to allow authenticating and obtaining Google APIs tokens
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
